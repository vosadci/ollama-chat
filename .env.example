# Copy this file to .env and adjust as needed.
# All values shown are defaults — only override what you need to change.

# Ollama — runs natively on the host (not in Docker)
# Docker containers reach it via host.docker.internal
OLLAMA_URL=http://host.docker.internal:11434

# LLM models (must be pulled: ollama pull <model>)
MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text

# Backend server
HOST=0.0.0.0
PORT=8000

# Paths inside the backend container — do not change unless remapping volumes
# DATA_PATH points to the sample documents included with the repo.
# Replace with your own HTML directory to index custom content.
DATA_PATH=/app/data/sample
CHROMA_PATH=/app/chroma_db

# CORS — comma-separated list of allowed frontend origins.
# Restrict to your actual domain(s) in production.
# CORS_ORIGINS=http://localhost:3000,https://chat.example.com

# RAG retrieval tuning
# See docs/rag-hyperparameter-tuning.md for guidance on each parameter.
# Changing RAG_CHUNK_SIZE or RAG_CHUNK_OVERLAP requires deleting chroma_db/ and reindexing.
# The remaining parameters only affect query-time behaviour — no reindex needed.
# RAG_CHUNK_SIZE=800
# RAG_CHUNK_OVERLAP=80
# RAG_SEMANTIC_CANDIDATES=15
# RAG_BM25_CANDIDATES=15
# RAG_TOP_K=5
# RAG_MMR_LAMBDA=0.7
