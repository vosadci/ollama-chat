# Copy this file to .env and adjust as needed.
# All values shown are defaults — only override what you need to change.

# Ollama — runs natively on the host (not in Docker)
# Docker containers reach it via host.docker.internal
OLLAMA_URL=http://host.docker.internal:11434

# LLM models (must be pulled: ollama pull <model>)
MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text

# Backend server
HOST=0.0.0.0
PORT=8000

# Paths inside the backend container — do not change unless remapping volumes
# DATA_PATH points to the sample documents included with the repo.
# Replace with your own HTML directory to index custom content.
DATA_PATH=/app/data/sample
CHROMA_PATH=/app/chroma_db
